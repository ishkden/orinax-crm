generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ORG (мультитенантность) ───────────────────────────────────────────────────
//
// Эта таблица — read-replica / кэш мастер-записи из SSO (основное Next.js-приложение).
// Записи сюда попадают при первом обращении пользователя или через webhook от SSO.
// Доступ к любому ресурсу CRM авторизуется по orgId, совпадающему с Org.externalId.
//
// НИКОГДА не создавать Org напрямую через CRM-UI — только через SSO или sync-endpoint.

model Org {
  id         String   @id @default(cuid())
  /// ID организации в мастер-базе SSO (внешний ключ экосистемы)
  externalId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members        OrgMember[]
  companies      Company[]
  contacts       Contact[]
  deals          Deal[]
  tasks          Task[]
  activities     Activity[]
  comments       Comment[]
  conversations  Conversation[]
  leads          Lead[]
  pipelines      Pipeline[]
  stages         Stage[]
  dealContacts   DealContact[]
  channels       CommunicationChannel[]
  stageHistories StageHistory[]
  customFields   CustomField[]
}

// Связь User ↔ Org через промежуточную таблицу (один user — много org)
model OrgMember {
  id       String        @id @default(cuid())
  userId   String
  orgId    String
  role     OrgMemberRole @default(AGENT)
  joinedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

// ─── AUTH (NextAuth.js / @auth/prisma-adapter) ────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(AGENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orgId                String?
  lastName             String?
  patronymic           String?
  phone                String?
  internalPhone        String?
  department           String?
  birthDate            DateTime? @db.Date
  gender               String?
  city                 String?
  notificationLanguage String?   @default("ru")
  position             String?
  lastSeenAt           DateTime?

  accounts   Account[]
  sessions   Session[]
  orgs       OrgMember[]
  contacts   Contact[]   @relation("AssignedContacts")
  deals      Deal[]      @relation("AssignedDeals")
  tasks      Task[]      @relation("AssignedTasks")
  activities Activity[]
  comments   Comment[]
  messages   Message[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CRM CORE ─────────────────────────────────────────────────────────────────

model Company {
  id       String  @id @default(cuid())
  orgId    String
  sourceId String?
  name     String
  industry String?
  phone    String?
  email    String?
  website  String?
  address  String?
  inn      String?

  customFields      Json?
  customFieldValues Json?
  isDeleted         Boolean   @default(false)
  syncedAt          DateTime?
  bitrixUpdatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org                    @relation(fields: [orgId], references: [id])
  contacts Contact[]
  deals    Deal[]                 @relation("CompanyDeals")
  leads    Lead[]
  channels CommunicationChannel[] @relation("CompanyChannels")

  @@unique([orgId, sourceId])
}

model Contact {
  serialNumber Int    @unique @default(autoincrement())
  id        String        @id @default(cuid())
  orgId     String
  firstName String
  lastName  String
  email     String?
  phone     String?
  company   String?
  position  String?
  source    ContactSource @default(MANUAL)
  status    ContactStatus @default(LEAD)
  notes     String?       @db.Text
  tags      String[]

  sourceId         String?
  connectorChatIds String[]
  primaryIM        String?
  customFields      Json?
  customFieldValues Json?
  isDeleted         Boolean   @default(false)
  syncedAt          DateTime?
  bitrixUpdatedAt   DateTime?

  companyId  String?
  assignedId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org           Org                    @relation(fields: [orgId], references: [id])
  companyRel    Company?               @relation(fields: [companyId], references: [id])
  assigned      User?                  @relation("AssignedContacts", fields: [assignedId], references: [id])
  deals         Deal[]
  tasks         Task[]
  activities    Activity[]             @relation("ContactActivities")
  comments      Comment[]
  conversations Conversation[]
  leads         Lead[]
  dealContacts  DealContact[]
  channels      CommunicationChannel[] @relation("ContactChannels")

  @@unique([orgId, sourceId])
}

model Pipeline {
  id        String   @id @default(cuid())
  orgId     String
  sourceId  String?
  name      String
  sortOrder Int      @default(0)
  section   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Org     @relation(fields: [orgId], references: [id])
  stages Stage[]
  deals  Deal[]

  @@unique([orgId, sourceId])
}

model Stage {
  id         String   @id @default(cuid())
  orgId      String
  pipelineId String
  sourceId   String?
  name       String
  color      String?
  sortOrder  Int      @default(0)
  isFinal    Boolean  @default(false)
  isWon      Boolean  @default(false)
  semantics  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id])
  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  deals    Deal[]

  stageHistoriesFrom StageHistory[] @relation("StageFrom")
  stageHistoriesTo   StageHistory[] @relation("StageTo")

  @@unique([orgId, sourceId])
}

model Deal {
  id           String @id @default(cuid())
  serialNumber Int    @unique @default(autoincrement())
  orgId        String
  title        String
  value       Float     @default(0)
  currency    String    @default("RUB")
  stage       DealStage @default(LEAD)
  priority    Priority  @default(MEDIUM)
  contactId   String?
  companyId   String?
  assignedId  String?
  closeDate   DateTime?
  description String?   @db.Text
  tags        String[]

  sourceId String?

  pipelineId String?
  stageId    String?

  rawPayload           Json?
  currencyId           String?
  assignedByExternalId String?
  createdById          String?
  modifyById           String?
  stageSemanticId      String?
  sourceDescription    String?
  beginDate            DateTime?
  movedTime            DateTime?
  lastActivityTime     DateTime?
  lastActivityBy       String?
  dateCreate           DateTime?
  dateModify           DateTime?

  customFieldValues Json?

  isDeleted       Boolean   @default(false)
  syncedAt        DateTime?
  bitrixUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org          Org            @relation(fields: [orgId], references: [id])
  contact      Contact?       @relation(fields: [contactId], references: [id])
  company      Company?       @relation("CompanyDeals", fields: [companyId], references: [id])
  assigned     User?          @relation("AssignedDeals", fields: [assignedId], references: [id])
  pipeline     Pipeline?      @relation(fields: [pipelineId], references: [id])
  stageRel     Stage?         @relation(fields: [stageId], references: [id])
  tasks        Task[]
  activities   Activity[]     @relation("DealActivities")
  comments     Comment[]
  dealContacts DealContact[]
  stageHistory StageHistory[]

  @@unique([orgId, sourceId])
  @@index([pipelineId])
  @@index([stageId])
}

// ─── Deal-Contact Junction (Bitrix deals can have multiple contacts) ─────────

model DealContact {
  id        String  @id @default(cuid())
  orgId     String
  dealId    String
  contactId String
  isPrimary Boolean @default(false)

  isDeleted       Boolean   @default(false)
  syncedAt        DateTime?
  bitrixUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Org     @relation(fields: [orgId], references: [id])
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@index([dealId])
  @@index([contactId])
}

// ─── Communication Channels (multiple phones/emails/IM per contact/company) ──

model CommunicationChannel {
  id        String      @id @default(cuid())
  orgId     String
  contactId String?
  companyId String?
  type      ChannelKind
  value     String
  isPrimary Boolean     @default(false)

  messengerType String?
  sourceId      String?

  isDeleted       Boolean   @default(false)
  syncedAt        DateTime?
  bitrixUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Org      @relation(fields: [orgId], references: [id])
  contact Contact? @relation("ContactChannels", fields: [contactId], references: [id], onDelete: Cascade)
  company Company? @relation("CompanyChannels", fields: [companyId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([companyId])
}

// ─── Stage History (deal stage transitions) ──────────────────────────────────

model StageHistory {
  id          String   @id @default(cuid())
  orgId       String
  dealId      String
  fromStageId String?
  toStageId   String
  movedAt     DateTime @default(now())
  sourceId    String?

  createdAt DateTime @default(now())

  org       Org    @relation(fields: [orgId], references: [id])
  deal      Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage Stage? @relation("StageFrom", fields: [fromStageId], references: [id])
  toStage   Stage  @relation("StageTo", fields: [toStageId], references: [id])

  @@index([dealId])
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  orgId       String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  contactId   String?
  dealId      String?
  assignedId  String?

  sourceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])
  assigned User?     @relation("AssignedTasks", fields: [assignedId], references: [id])
  comments Comment[]
}

// ─── Activities ──────────────────────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  orgId     String
  type      ActivityType
  title     String
  body      String?      @db.Text
  userId    String?
  contactId String?
  dealId    String?

  sourceId     String?
  direction    String?
  duration     Int?
  recordingUrl String?
  metadata     Json?

  createdAt DateTime @default(now())

  org     Org      @relation(fields: [orgId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  contact Contact? @relation("ContactActivities", fields: [contactId], references: [id])
  deal    Deal?    @relation("DealActivities", fields: [dealId], references: [id])

  @@index([dealId])
  @@index([contactId])
  @@index([orgId, sourceId])
}

// ─── Comments ────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  orgId     String
  body      String   @db.Text
  userId    String?
  contactId String?
  dealId    String?
  taskId    String?

  sourceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Org      @relation(fields: [orgId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@index([dealId])
}

// ─── ЧАТЫ / КОННЕКТОР ─────────────────────────────────────────────────────────

model Conversation {
  id         String              @id @default(cuid())
  orgId      String
  contactId  String?
  channel    ConversationChannel
  externalId String?
  status     ConversationStatus  @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  messages Message[]

  @@index([externalId])
  @@index([orgId, status])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  sourceId       String?
  authorId       String?
  fromExternal   Boolean  @default(false)
  body           String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id])

  @@unique([conversationId, sourceId])
  @@index([conversationId, createdAt])
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

enum ContactSource {
  MANUAL
  IMPORT
  API
  ORINAX_ANALYTICS
  ORINAX_CONNECTORS
  WEBSITE
  REFERRAL
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  SMS
  TASK_BITRIX
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  CONTACT_CREATED
  TASK_CREATED
  TASK_COMPLETED
}

enum ChannelKind {
  PHONE
  EMAIL
  IM
}

enum ConversationChannel {
  TELEGRAM
  WHATSAPP
  VK
  INSTAGRAM
  WIDGET
  EMAIL
  OTHER
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

// ─── Custom Fields ────────────────────────────────────────────────────────────

enum CustomFieldEntityType {
  DEAL
  CONTACT
  COMPANY
  LEAD
}

enum CustomFieldType {
  STRING
  TEXT
  LIST
  DATETIME
  DATE
  RESOURCE
  ADDRESS
  URL
  FILE
  MONEY
  BOOLEAN
  NUMBER
}

model CustomField {
  id        String          @id @default(cuid())
  orgId     String
  code      String          @unique
  name      String
  type       CustomFieldType
  entityType CustomFieldEntityType @default(DEAL)
  options    Json?
  required  Boolean         @default(false)
  sortOrder Int             @default(0)
  section   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, entityType])
}

// ─── SYSTEM SETTINGS (key-value store for admin config) ──────────────────────

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Lead {
  id              String   @id @default(cuid())
  orgId           String
  sourceId        String?
  title           String?
  statusId        String?
  statusSemantic  String?
  value           Float    @default(0)
  currency        String   @default("RUB")
  contactId       String?
  companyId       String?
  assignedId      String?
  description     String?  @db.Text
  tags            String[]
  contactSourceId String?
  companySourceId String?

  rawPayload           Json?
  assignedByExternalId String?
  createdById          String?
  modifyById           String?
  sourceDescription    String?
  dateCreate           DateTime?
  dateModify           DateTime?

  customFieldValues Json?

  isDeleted       Boolean   @default(false)
  syncedAt        DateTime?
  bitrixUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Org      @relation(fields: [orgId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@unique([orgId, sourceId])
}
