generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ORG (мультитенантность) ───────────────────────────────────────────────────
//
// Эта таблица — read-replica / кэш мастер-записи из SSO (основное Next.js-приложение).
// Записи сюда попадают при первом обращении пользователя или через webhook от SSO.
// Доступ к любому ресурсу CRM авторизуется по orgId, совпадающему с Org.externalId.
//
// НИКОГДА не создавать Org напрямую через CRM-UI — только через SSO или sync-endpoint.

model Org {
  id         String   @id @default(cuid())
  /// ID организации в мастер-базе SSO (внешний ключ экосистемы)
  externalId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members       OrgMember[]
  companies     Company[]
  contacts      Contact[]
  deals         Deal[]
  tasks         Task[]
  activities    Activity[]
  comments      Comment[]
  conversations Conversation[]
  pipelines     Pipeline[]
  stages        Stage[]
}

// Связь User ↔ Org через промежуточную таблицу (один user — много org)
model OrgMember {
  id       String        @id @default(cuid())
  userId   String
  orgId    String
  role     OrgMemberRole @default(AGENT)
  joinedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

// ─── AUTH (NextAuth.js / @auth/prisma-adapter) ────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(AGENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  orgs       OrgMember[]
  contacts   Contact[]   @relation("AssignedContacts")
  deals      Deal[]      @relation("AssignedDeals")
  tasks      Task[]      @relation("AssignedTasks")
  activities Activity[]
  comments   Comment[]
  messages   Message[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CRM CORE ─────────────────────────────────────────────────────────────────

model Company {
  id       String   @id @default(cuid())
  orgId    String
  sourceId String?  // ID в Битрикс24 (из сервиса Аналитики)
  name     String
  industry String?
  phone    String?
  email    String?
  website  String?
  address  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  contacts Contact[]

  @@unique([orgId, sourceId])
}

model Contact {
  id        String        @id @default(cuid())
  orgId     String
  firstName String
  lastName  String
  email     String?
  phone     String?
  company   String?
  position  String?
  source    ContactSource @default(MANUAL)
  status    ContactStatus @default(LEAD)
  notes     String?       @db.Text
  tags      String[]

  // Маппинг внешних источников
  sourceId         String?  // ID в Битрикс24 (из сервиса Аналитики)
  connectorChatIds String[] // ID чатов в сервисе Коннектора

  companyId  String?
  assignedId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org           Org            @relation(fields: [orgId], references: [id])
  companyRel    Company?       @relation(fields: [companyId], references: [id])
  assigned      User?          @relation("AssignedContacts", fields: [assignedId], references: [id])
  deals         Deal[]
  tasks         Task[]
  activities    Activity[]     @relation("ContactActivities")
  comments      Comment[]
  conversations Conversation[]

  @@unique([orgId, sourceId])
}

model Pipeline {
  id        String   @id @default(cuid())
  orgId     String
  sourceId  String?
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Org     @relation(fields: [orgId], references: [id])
  stages Stage[]
  deals  Deal[]

  @@unique([orgId, sourceId])
}

model Stage {
  id         String   @id @default(cuid())
  orgId      String
  pipelineId String
  sourceId   String?
  name       String
  color      String?
  sortOrder  Int      @default(0)
  isFinal    Boolean  @default(false)
  isWon      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id])
  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  deals    Deal[]

  @@unique([orgId, sourceId])
}

model Deal {
  id          String    @id @default(cuid())
  orgId       String
  title       String
  value       Float     @default(0)
  currency    String    @default("RUB")
  stage       DealStage @default(LEAD)
  priority    Priority  @default(MEDIUM)
  contactId   String?
  assignedId  String?
  closeDate   DateTime?
  description String?   @db.Text
  tags        String[]

  // Маппинг внешних источников
  sourceId String? // ID в Битрикс24 (из сервиса Аналитики)

  // Динамические воронки и стадии (из Аналитики / Битрикса)
  pipelineId String?
  stageId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org        Org        @relation(fields: [orgId], references: [id])
  contact    Contact?   @relation(fields: [contactId], references: [id])
  assigned   User?      @relation("AssignedDeals", fields: [assignedId], references: [id])
  pipeline   Pipeline?  @relation(fields: [pipelineId], references: [id])
  stageRel   Stage?     @relation(fields: [stageId], references: [id])
  tasks      Task[]
  activities Activity[] @relation("DealActivities")
  comments   Comment[]

  @@unique([orgId, sourceId])
}

model Task {
  id          String     @id @default(cuid())
  orgId       String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  contactId   String?
  dealId      String?
  assignedId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])
  assigned User?     @relation("AssignedTasks", fields: [assignedId], references: [id])
  comments Comment[]
}

model Activity {
  id        String       @id @default(cuid())
  orgId     String
  type      ActivityType
  title     String
  body      String?      @db.Text
  userId    String
  contactId String?
  dealId    String?
  createdAt DateTime     @default(now())

  org     Org      @relation(fields: [orgId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  contact Contact? @relation("ContactActivities", fields: [contactId], references: [id])
  deal    Deal?    @relation("DealActivities", fields: [dealId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  orgId     String
  body      String   @db.Text
  userId    String
  contactId String?
  dealId    String?
  taskId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Org      @relation(fields: [orgId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
}

// ─── ЧАТЫ / КОННЕКТОР ─────────────────────────────────────────────────────────

model Conversation {
  id         String              @id @default(cuid())
  orgId      String
  contactId  String?
  channel    ConversationChannel
  externalId String?             // ID чата в сервисе Коннектора
  status     ConversationStatus  @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  messages Message[]

  @@index([externalId])
  @@index([orgId, status])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  sourceId       String?  // ID в Битрикс24 (из сервиса Аналитики)
  authorId       String?  // User.id, null если сообщение от клиента
  fromExternal   Boolean  @default(false) // true = от клиента, false = от агента
  body           String?  @db.Text
  metadata       Json?    // Служебная инфа от коннектора: типы вложений, messageId и т.д.
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id])

  @@unique([conversationId, sourceId])
  @@index([conversationId, createdAt])
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

enum ContactSource {
  MANUAL
  IMPORT
  API
  ORINAX_ANALYTICS
  ORINAX_CONNECTORS
  WEBSITE
  REFERRAL
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  CONTACT_CREATED
  TASK_CREATED
  TASK_COMPLETED
}

enum ConversationChannel {
  TELEGRAM
  WHATSAPP
  VK
  INSTAGRAM
  WIDGET
  EMAIL
  OTHER
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}
